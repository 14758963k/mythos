# ─── Mythos ⟁ Ascendant ──────────────────────────────────────────────────────
# Copy this file to `.env` and fill the values before starting the bot.

# Phone number used for pairing code login (no '+' sign, no spaces, no dashes)
PAIRING_NUMBER=

# Owner JID(s) (comma separated). Owner commands will only work for these.
OWNER_JIDS=

# Bot display name
BOT_NAME=Mythos

# Bot thumbnail URL (shown in branded cards)
BOT_THUMBNAIL=https://files.catbox.moe/k3j8m1.jpg

# Primary command prefix (one character). Changeable at runtime with .setprefix.
PREFIX=.

# Log level: silent | error | warn | info | debug
LOG_LEVEL=silent

# Print QR code to terminal on first run
PRINT_QR=true

# Auth session folder (relative to project root)
AUTH_DIR=auth_info

# Data store: "json" (default) or "sqlite"
STORE_BACKEND=json

# ─── Feature Toggles ──────────────────────────────────────────────────────────
READ_STATUS=false
AUTO_REACT=false
AUTO_BIO=false
ANTI_DELETE=false
ANTI_SPAM=false
ANTI_BADWORD=false
AUTO_STATUS_VIEW=false

# ─── Chatbot ──────────────────────────────────────────────────────────────────
CHATBOT=false
CHATBOT_SYSTEM=You are Mythos, GOATED-404 Labs assistant built by Stiletto (Kimani). Reply concisely. Do not use emojis.

# ─── AI Providers (set at least one) ─────────────────────────────────────────
# Default provider for .ai command and chatbot
AI_PROVIDER=mistral

# Mistral AI
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# OpenAI (GPT)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Anthropic Claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── External APIs ────────────────────────────────────────────────────────────
# Google Custom Search (for .google and .image commands)
GOOGLE_API_KEY=
GOOGLE_CX=

# Meta WhatsApp Flows (for galaxy_message button)
META_FLOW_ID=
META_FLOW_TOKEN=
