# ─── Mythos ⟁ Ascendant ──────────────────────────────────────────────────────
# Copy this file to `.env` and fill the values before starting the bot.

# Phone number used for pairing code login (no '+' sign, no spaces, no dashes)
# Example: 254712345678
PAIRING_NUMBER=

# Owner JID(s) (comma separated). Owner commands will only work for these.
# Example: 254712345678@s.whatsapp.net
OWNER_JIDS=

# Bot display name (shown in the menu, owner, and about)
BOT_NAME=Mythos

# Bot thumbnail URL (shown in branded cards below messages)
BOT_THUMBNAIL=https://files.catbox.moe/k3j8m1.jpg

# Primary command prefix (use one character). You can also change this at runtime
# with the .setprefix command if you are the owner.
PREFIX=.

# Log level for the Baileys socket logger (silent | error | warn | info | debug)
LOG_LEVEL=silent

# When true, the bot will print the QR code to the terminal on first run.
PRINT_QR=true

# Path to the auth/session folder (relative to project root)
AUTH_DIR=auth_info

# Data store backend. "json" (default) or "sqlite".
# SQLite will auto-migrate your existing JSON files on first run.
STORE_BACKEND=json

# Path to the SQLite database file (only used when STORE_BACKEND=sqlite).
# Defaults to src/data/mythos.db if unset.
# SQLITE_PATH=

# Log file path. Defaults to src/data/mythos.log if unset.
# Set to an empty string to disable file logging.
# LOG_FILE=

# ─── Feature Toggles ──────────────────────────────────────────────────────────
# Read everyone's status/stories automatically
READ_STATUS=false

# Auto-react with random emoji to every command invocation
AUTO_REACT=false

# Auto-update the bot's WhatsApp bio with uptime
AUTO_BIO=false

# Recover and forward deleted messages
ANTI_DELETE=false

# Global chatbot toggle (AI auto-reply to every message)
CHATBOT=false

# Mistral AI API key (for chatbot)
# Get one at: https://console.mistral.ai/
MISTRAL_API_KEY=

# Mistral model to use (default: mistral-small-latest)
CHATBOT_MODEL=mistral-small-latest

# System prompt for the chatbot
CHATBOT_SYSTEM=You are Mythos, a helpful WhatsApp assistant. Reply concisely. Do not use emojis.

# Google Custom Search API Key (for .google and .image commands)
# Get one at: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=

# Google Search Engine ID (for .google and .image commands)
GOOGLE_CX=

# Meta WhatsApp Flows (for galaxy_message button)
# Get from: Meta Business Suite > WhatsApp > Flows
META_FLOW_ID=
META_FLOW_TOKEN=
